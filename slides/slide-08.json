  "title": "Writes stay narrow",
  "eyebrow": "Safety model",
  "summary": "The studio can mutate slides, repo-local state, and generated artifacts, but not arbitrary project files.",
  "signalsTitle": "Allowed write targets",
  "guardrailsTitle": "Change discipline",
  "signals": [
    {
      "id": "signal-slides",
      "title": "slides/slide-*",
      "body": "Structured deck content."
    },
    {
      "id": "signal-state",
      "title": "studio/state/*.json",
      "body": "Context, settings, sessions."
    },
    {
      "id": "signal-output",
      "title": "studio/output/**",
      "body": "Generated workflow artifacts."
    },
    {
      "id": "signal-audit",
      "title": "Archive PDF",
      "body": "Validated project snapshot."
    }
  ],
  "guardrails": [
    {
      "id": "guardrail-allowlist",
      "title": "Small allowlist",
      "body": "Reject unapproved paths."
    },
    {
      "id": "guardrail-conflict",
      "title": "Overlap checks",
      "body": "Reject conflicting edits."
    },
    {
      "id": "guardrail-archive",
